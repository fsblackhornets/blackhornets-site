# Production .htaccess for cPanel
Options -Indexes +FollowSymLinks

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Block direct access to src/ directory
    RewriteRule ^src(/|$) - [F,L]

    # Root URL -> public/index.html
    RewriteRule ^$ /public/index.html [L]

    # Remove /fsbh/ from URL if present
    RewriteCond %{REQUEST_URI} ^/fsbh/(.*)$
    RewriteRule ^fsbh/(.*)$ /$1 [R=301,L]

    # Redirect root to public folder
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ /public/$1 [L]

    # If accessing /public/ directly, keep it
    RewriteCond %{REQUEST_URI} ^/public/
    RewriteRule ^ - [L]
</IfModule>

# Security Headers
<IfModule mod_headers.c>
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set X-Content-Type-Options "nosniff"
</IfModule>

# Disable Directory Browsing
Options -Indexes

# Custom Error Pages
ErrorDocument 404 /public/index.html
ErrorDocument 403 /public/index.html
ErrorDocument 500 /public/index.html

# Protect sensitive files (using FilesMatch instead of DirectoryMatch)
<FilesMatch "^(database\.php|\.env|config\.php|\.gitignore|composer\.(json|lock)|package(-lock)?\.json)$">
    Require all denied
</FilesMatch>

# Block access to .git files
<FilesMatch "^\.git">
    Require all denied
</FilesMatch>

# Set UTF-8 encoding
AddDefaultCharset UTF-8

# File upload limits (adjust if needed)
php_value upload_max_filesize 10M
php_value post_max_size 10M
php_value max_execution_time 300
php_value max_input_time 300
